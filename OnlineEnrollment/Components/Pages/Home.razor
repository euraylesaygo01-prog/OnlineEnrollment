@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using OnlineEnrollment.Models
@inject OnlineEnrollment.Data.AppDbContext DB
@inject NavigationManager Nav

<div class="login-bg">
    <div class="login-card">
        <div class="login-logo">
            <span class="logo-icon">🎓</span>
            <h1>Online Enrollment</h1>
            <p>Student Portal</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" @bind="email" placeholder="Enter your email" class="form-input" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="password" placeholder="Enter your password" class="form-input" />
        </div>

        <button class="btn-login" @onclick="HandleLogin">Login</button>

        <div class="login-links">
            <a href="/register">Create an Account</a>
            <a href="/forgot-password">Forgot Password?</a>
        </div>
    </div>
</div>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0e2e; }

    .login-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 48px 40px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 36px;
    }

    .logo-icon {
        font-size: 48px;
        display: block;
        margin-bottom: 12px;
    }

    .login-logo h1 {
        color: #fff;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .login-logo p {
        color: rgba(255,255,255,0.5);
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: border-color 0.3s;
    }

    .form-input:focus {
        border-color: #4f8ef7;
    }

    .form-input::placeholder {
        color: rgba(255,255,255,0.3);
    }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #4f8ef7, #2563eb);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.3s;
    }

    .btn-login:hover { opacity: 0.9; }

    .login-links {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
    }

    .login-links a {
        color: #4f8ef7;
        font-size: 13px;
        text-decoration: none;
    }

    .login-links a:hover { text-decoration: underline; }

    .alert-error {
        background: rgba(239,68,68,0.15);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 20px;
    }
</style>

@code {
    string email = "";
    string password = "";
    string errorMessage = "";

    async Task HandleLogin()
    {
        errorMessage = "";

        var admin = await DB.AdminUsers.FirstOrDefaultAsync(a => a.Email == email && a.Password == password);
        if (admin != null)
        {
            Nav.NavigateTo("/admin");
            return;
        }

        var student = await DB.Students.FirstOrDefaultAsync(s => s.Email == email && s.Password == password);
        if (student != null)
        {
            Nav.NavigateTo($"/courses/{student.Id}");
            return;
        }

        errorMessage = "Invalid email or password.";
    }
}
@page "/register"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using OnlineEnrollment.Models
@inject OnlineEnrollment.Data.AppDbContext DB
@inject NavigationManager Nav

<div class="login-bg">
    <div class="register-card">
        <div class="login-logo">
            <span class="logo-icon">🎓</span>
            <h1>Online Enrollment</h1>
            <p>Create your account</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        <div class="form-row">
            <div class="form-group">
                <label>First Name</label>
                <input @bind="firstName" placeholder="First name" class="form-input" />
            </div>
            <div class="form-group">
                <label>Last Name</label>
                <input @bind="lastName" placeholder="Last name" class="form-input" />
            </div>
        </div>

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" @bind="email" placeholder="Enter your email" class="form-input" />
        </div>

        <div class="form-group">
            <label>Phone Number</label>
            <input @bind="phone" placeholder="Enter your phone number" class="form-input" />
        </div>

        <div class="form-group">
            <label>Address</label>
            <input @bind="address" placeholder="Enter your address" class="form-input" />
        </div>

        <div class="form-group">
            <label>Birth Date</label>
            <input type="date" @bind="birthDate" class="form-input" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" @bind="password" placeholder="Create a password" class="form-input" />
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            <input type="password" @bind="confirmPassword" placeholder="Confirm your password" class="form-input" />
        </div>

        <button class="btn-login" @onclick="HandleRegister">Create Account</button>

        <div class="login-links">
            <a href="/">Already have an account? Login</a>
        </div>
    </div>
</div>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    .login-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
        padding: 40px 20px;
    }

    .register-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 48px 40px;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 36px;
    }

    .logo-icon {
        font-size: 48px;
        display: block;
        margin-bottom: 12px;
    }

    .login-logo h1 {
        color: #fff;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .login-logo p {
        color: rgba(255,255,255,0.5);
        font-size: 14px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: border-color 0.3s;
    }

    .form-input:focus { border-color: #4f8ef7; }
    .form-input::placeholder { color: rgba(255,255,255,0.3); }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #4f8ef7, #2563eb);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.3s;
    }

    .btn-login:hover { opacity: 0.9; }

    .login-links {
        text-align: center;
        margin-top: 20px;
    }

    .login-links a {
        color: #4f8ef7;
        font-size: 13px;
        text-decoration: none;
    }

    .login-links a:hover { text-decoration: underline; }

    .alert-error {
        background: rgba(239,68,68,0.15);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 20px;
    }
</style>

@code {
    string firstName = "";
    string lastName = "";
    string email = "";
    string phone = "";
    string address = "";
    DateTime birthDate = DateTime.Today;
    string password = "";
    string confirmPassword = "";
    string errorMessage = "";

    async Task HandleRegister()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName) ||
            string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please fill in all required fields.";
            return;
        }

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        var exists = await DB.Students.AnyAsync(s => s.Email == email);
        if (exists)
        {
            errorMessage = "Email already registered.";
            return;
        }

        var count = await DB.Students.CountAsync();
        var studentNumber = $"2024-{(count + 1):D5}";

        var student = new Student
        {
            FirstName = firstName,
            LastName = lastName,
            Email = email,
            Phone = phone,
            Address = address,
            BirthDate = birthDate,
            Password = password,
            StudentNumber = studentNumber,
            Status = "Pending",
            RegisteredAt = DateTime.Now
        };

        DB.Students.Add(student);
        await DB.SaveChangesAsync();

        Nav.NavigateTo($"/confirmation/{firstName}");
    }
}
@page "/forgot-password"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using OnlineEnrollment.Models
@inject OnlineEnrollment.Data.AppDbContext DB
@inject NavigationManager Nav

<div class="login-bg">
    <div class="login-card">
        <div class="login-logo">
            <span class="logo-icon">🎓</span>
            <h1>Online Enrollment</h1>
            <p>Reset your password</p>
        </div>

        @if (step == 1)
        {
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" @bind="email" placeholder="Enter your email" class="form-input" />
            </div>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">@errorMessage</div>
            }
            <button class="btn-login" @onclick="FindAccount">Find Account</button>
        }
        else if (step == 2)
        {
            <div class="form-group">
                <label>New Password</label>
                <input type="password" @bind="newPassword" placeholder="Enter new password" class="form-input" />
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" @bind="confirmPassword" placeholder="Confirm new password" class="form-input" />
            </div>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">@errorMessage</div>
            }
            <button class="btn-login" @onclick="ResetPassword">Reset Password</button>
        }
        else if (step == 3)
        {
            <div class="success-msg">
                <div class="success-icon">✅</div>
                <p>Password reset successfully!</p>
            </div>
            <button class="btn-login" @onclick='() => Nav.NavigateTo("/")'>Back to Login</button>
        }

        <div class="login-links">
            <a href="/">Back to Login</a>
        </div>
    </div>
</div>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    .login-bg {
        min-height: 100vh;
        background: linear-gradient(135deg, #0a0e2e 0%, #1a1f4e 50%, #0d1537 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Segoe UI', sans-serif;
    }

    .login-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 24px;
        padding: 48px 40px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    .login-logo {
        text-align: center;
        margin-bottom: 36px;
    }

    .logo-icon {
        font-size: 48px;
        display: block;
        margin-bottom: 12px;
    }

    .login-logo h1 {
        color: #fff;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .login-logo p {
        color: rgba(255,255,255,0.5);
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: rgba(255,255,255,0.7);
        font-size: 13px;
        margin-bottom: 8px;
        font-weight: 500;
    }

    .form-input {
        width: 100%;
        padding: 12px 16px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 10px;
        color: #fff;
        font-size: 14px;
        outline: none;
        transition: border-color 0.3s;
    }

    .form-input:focus { border-color: #4f8ef7; }
    .form-input::placeholder { color: rgba(255,255,255,0.3); }

    .btn-login {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #4f8ef7, #2563eb);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.3s;
    }

    .btn-login:hover { opacity: 0.9; }

    .login-links {
        text-align: center;
        margin-top: 20px;
    }

    .login-links a {
        color: #4f8ef7;
        font-size: 13px;
        text-decoration: none;
    }

    .login-links a:hover { text-decoration: underline; }

    .alert-error {
        background: rgba(239,68,68,0.15);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 13px;
        margin-bottom: 20px;
    }

    .success-msg {
        text-align: center;
        margin-bottom: 24px;
    }

    .success-icon { font-size: 48px; margin-bottom: 12px; }

    .success-msg p {
        color: rgba(255,255,255,0.7);
        font-size: 15px;
    }
</style>

@code {
    int step = 1;
    string email = "";
    string newPassword = "";
    string confirmPassword = "";
    string errorMessage = "";
    Student? foundStudent;

    async Task FindAccount()
    {
        errorMessage = "";
        foundStudent = await DB.Students.FirstOrDefaultAsync(s => s.Email == email);
        if (foundStudent == null)
        {
            errorMessage = "No account found with that email.";
            return;
        }
        step = 2;
    }

    async Task ResetPassword()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Please enter a new password.";
            return;
        }
        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }
        if (foundStudent != null)
        {
            foundStudent.Password = newPassword;
            await DB.SaveChangesAsync();
        }
        step = 3;
    }
}